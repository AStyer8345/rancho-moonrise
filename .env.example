# Vercel project env vars for rancho-moonrise (marketing site)
# Set these in Vercel Project Settings → Environment Variables.

# --- /api/inquiry — webform → rancho-crm webhook ---

# Full URL of the CRM webhook endpoint.
RANCHO_CRM_WEBHOOK_URL=https://rancho-crm.vercel.app/api/crm/webhook/inquiry

# Shared secret matching the CRM's RANCHO_API_KEY env var. The marketing
# site holds it server-side so it never ships to the browser.
RANCHO_API_KEY=

# --- /api/complete — improvement-plan "Mark done" button ---

# Shared secret Adam pastes once on the improvement-plan page (same value
# used by client-ops). Stored in localStorage on his browser.
BRIEFING_AUTH_TOKEN=

# Fine-grained PAT scoped to AStyer8345/rancho-moonrise contents:write.
# TODO: rotate from the broad-scoped `gh auth token` bootstrap value.
GITHUB_TOKEN=

# Optional overrides — defaults shown.
GITHUB_OWNER=AStyer8345
GITHUB_REPO=rancho-moonrise
GITHUB_BRANCH=main
