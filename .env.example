# Vercel project env vars for rancho-moonrise (marketing site)
# Set these in Vercel Project Settings → Environment Variables.

# --- /api/inquiry — webform → email events@ → Gmail Poller (n8n) ---

# Resend API key. Get from https://resend.com/api-keys.
RESEND_API_KEY=

# FROM address for the form-relay email. Defaults to wordpress@ranchomoonrise.com
# which matches the Gmail Poller's `from:` filter exactly. Domain
# (ranchomoonrise.com) must be verified in Resend with SPF + DKIM TXT
# records — these are TXT records and don't conflict with the website's
# A/CNAME records. Safe to add today, even before DNS cutover.
INQUIRY_FROM_EMAIL=wordpress@ranchomoonrise.com

# TO address — the shared inbox the Gmail Poller watches.
INQUIRY_TO_EMAIL=events@ranchomoonrise.com

# --- /api/complete — improvement-plan "Mark done" button ---

# Shared secret Adam pastes once on the improvement-plan page (same value
# used by client-ops). Stored in localStorage on his browser.
BRIEFING_AUTH_TOKEN=

# Fine-grained PAT scoped to AStyer8345/rancho-moonrise contents:write.
# TODO: rotate from the broad-scoped `gh auth token` bootstrap value.
GITHUB_TOKEN=

# Optional overrides — defaults shown.
GITHUB_OWNER=AStyer8345
GITHUB_REPO=rancho-moonrise
GITHUB_BRANCH=main
