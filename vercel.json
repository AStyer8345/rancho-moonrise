{
  "outputDirectory": "site",
  "trailingSlash": true,
  "functions": {
    "api/complete.js": {
      "memory": 256,
      "maxDuration": 10
    },
    "api/inquiry.js": {
      "memory": 256,
      "maxDuration": 10
    }
  },
  "rewrites": [
    { "source": "/accommodations/", "destination": "/pages/accommodations.html" },
    { "source": "/weddings/", "destination": "/pages/weddings.html" },
    { "source": "/events/", "destination": "/pages/events.html" },
    { "source": "/host-your-event/", "destination": "/pages/host-your-event.html" },
    { "source": "/contact/", "destination": "/pages/contact.html" },
    { "source": "/faqs/", "destination": "/pages/faqs.html" },
    { "source": "/policies/", "destination": "/pages/policies.html" },
    { "source": "/accessibility/", "destination": "/pages/accessibility.html" },
    { "source": "/videos/", "destination": "/pages/videos.html" },
    { "source": "/safari-tents-near-austin/", "destination": "/pages/safari-tents-near-austin.html" },
    { "source": "/blog/", "destination": "/pages/blog.html" },
    { "source": "/blog/glamping-near-austin-texas/", "destination": "/pages/glamping-near-austin-texas.html" },
    { "source": "/blog/wedding-venues-near-austin/", "destination": "/pages/wedding-venues-near-austin.html" },
    { "source": "/blog/corporate-retreat-near-austin/", "destination": "/pages/corporate-retreat-near-austin.html" },
    { "source": "/blog/corporate-retreat-planning-guide-texas/", "destination": "/pages/corporate-retreat-planning-guide-texas.html" },
    { "source": "/blog/things-to-do-manor-tx/", "destination": "/pages/things-to-do-manor-tx.html" },
    { "source": "/blog/things-to-do-near-austin-with-kids/", "destination": "/pages/things-to-do-near-austin-with-kids.html" },
    { "source": "/blog/bachelorette-party-austin-texas/", "destination": "/pages/bachelorette-party-austin-texas.html" },
    { "source": "/blog/ranch-wedding-texas/", "destination": "/pages/ranch-wedding-texas.html" },
    { "source": "/blog/weekend-getaways-near-austin/", "destination": "/pages/weekend-getaways-near-austin.html" },
    { "source": "/blog/pool-day-pass-austin/", "destination": "/pages/pool-day-pass-austin.html" },
    { "source": "/blog/glamping-vs-camping/", "destination": "/pages/glamping-vs-camping.html" },
    { "source": "/blog/summer-glamping-near-austin/", "destination": "/pages/summer-glamping-near-austin.html" }
  ],
  "headers": [
    {
      "source": "/images/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/css/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/admin/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" },
        { "key": "X-Robots-Tag", "value": "noindex, nofollow" }
      ]
    },
    {
      "source": "/improvement-plan.html",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" },
        { "key": "X-Robots-Tag", "value": "noindex, nofollow" }
      ]
    },
    {
      "source": "/brand-audit.html",
      "headers": [
        { "key": "X-Robots-Tag", "value": "noindex, nofollow" }
      ]
    },
    {
      "source": "/mockup-preview.html",
      "headers": [
        { "key": "X-Robots-Tag", "value": "noindex, nofollow" }
      ]
    },
    {
      "source": "/dashboard.html",
      "headers": [
        { "key": "X-Robots-Tag", "value": "noindex, nofollow" }
      ]
    },
    {
      "source": "/report.html",
      "headers": [
        { "key": "X-Robots-Tag", "value": "noindex, nofollow" }
      ]
    },
    {
      "source": "/competitive-intelligence.html",
      "headers": [
        { "key": "X-Robots-Tag", "value": "noindex, nofollow" }
      ]
    },
    {
      "source": "/audits/(.*)",
      "headers": [
        { "key": "X-Robots-Tag", "value": "noindex, nofollow" }
      ]
    }
  ]
}
